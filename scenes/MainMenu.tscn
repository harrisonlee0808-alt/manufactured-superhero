[connection signal="pressed" from="MainLayout/Panel/Content/Buttons/PlayButton" to="." method="_on_play_button_pressed"]
[connection signal="pressed" from="MainLayout/Panel/Content/Buttons/CardsButton" to="." method="_on_cards_button_pressed"]
